generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Entity {
  id            String   @id @default(cuid())
  name          String
  type          String
  verified      Boolean  @default(false)
  logoUrl       String?
  chains        String[]
  totalUsdValue Float    @default(0)
  wallets       Wallet[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type])
  @@index([totalUsdValue(sort: Desc)])
}

model Wallet {
  id           String   @id @default(cuid())
  address      String   @unique
  chain        String
  entityId     String?
  entity            Entity?           @relation(fields: [entityId], references: [id])
  smartMoneyWallet  SmartMoneyWallet?
  labels            String[]
  riskScore         Int               @default(0)
  lastSeen     DateTime
  holdings     TokenHolding[]
  transactions Transaction[]
  createdAt    DateTime @default(now())

  @@index([chain])
  @@index([entityId])
}

model Token {
  id             String   @id @default(cuid())
  address        String
  chain          String
  name           String
  symbol         String
  price          Float    @default(0)
  marketCap      Float    @default(0)
  volume24h      Float    @default(0)
  holderCount    Int      @default(0)
  smartMoneyFlow Float    @default(0)
  holdings       TokenHolding[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([address, chain])
  @@index([smartMoneyFlow(sort: Desc)])
  @@index([volume24h(sort: Desc)])
}

model TokenHolding {
  id       String @id @default(cuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  tokenId  String
  token    Token  @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  amount   Float
  usdValue Float

  @@unique([walletId, tokenId])
  @@index([usdValue(sort: Desc)])
}

model Transaction {
  id        String @id @default(cuid())
  walletId  String
  wallet    Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  txHash    String
  value     Float
  timestamp DateTime

  @@unique([walletId, txHash])
  @@index([walletId, timestamp(sort: Desc)])
}

model PredictionMarket {
  id          String   @id @default(cuid())
  category    String
  symbol      String
  resolvedAt  DateTime?
  outcome     String?
  volume24h   Float    @default(0)
  totalVolume Float    @default(0)
  traderCount Int      @default(0)
  status      String   @default("open")
  trades      PredictionTrade[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, status])
  @@index([volume24h(sort: Desc)])
  @@index([totalVolume(sort: Desc)])
}

model PredictionTrade {
  id        String   @id @default(cuid())
  marketId  String
  market    PredictionMarket @relation(fields: [marketId], references: [id], onDelete: Cascade)
  wallet    String
  direction String
  shares    Float
  price     Float
  timestamp DateTime

  @@index([marketId, timestamp(sort: Desc)])
  @@index([wallet])
}

model Alert {
  id          String   @id @default(cuid())
  userId      String
  triggerType String
  conditions  Json
  isActive    Boolean  @default(true)
  lastFired   DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, isActive])
}

model SmartMoneyWallet {
  id       String   @id @default(cuid())
  walletId String   @unique
  wallet   Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  category String
  score    Float
  addedAt  DateTime @default(now())

  @@index([score(sort: Desc)])
  @@index([category])
}

model DeFiProtocol {
  id               String   @id @default(cuid())
  name             String
  chain            String
  category         String
  tvl              Float    @default(0)
  tvlChange24h     Float    @default(0)
  volume24h        Float    @default(0)
  uniqueUsers      Int      @default(0)
  smartMoneyInflow Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tvl(sort: Desc)])
  @@index([chain, category])
  @@index([smartMoneyInflow(sort: Desc)])
}

model NFTCollection {
  id             String   @id @default(cuid())
  name           String
  address        String   @unique
  chain          String
  floorPrice     Float    @default(0)
  volume24h      Float    @default(0)
  uniqueHolders  Int      @default(0)
  smartMoneyPct  Float    @default(0)
  washTradeScore Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([volume24h(sort: Desc)])
  @@index([floorPrice(sort: Desc)])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         String   @default("free")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model IndexerCheckpoint {
  id         String   @id @default(cuid())
  chain      String   @unique
  lastBlock  BigInt   @default(0)
  lastTxHash String?
  updatedAt  DateTime @updatedAt
}

model CexExchange {
  id                 String   @id @default(cuid())
  name               String   @unique
  status             String   @default("unknown")
  makerFee           Float    @default(0)
  takerFee           Float    @default(0)
  spotVolumeUsd24h   Float    @default(0)
  futuresVolumeUsd24h Float   @default(0)
  serverTime         DateTime?
  lastUpdate         DateTime @default(now())

  @@index([status])
}

model CexPair {
  id                  String   @id @default(cuid())
  exchange            String
  symbol              String
  baseSymbol          String
  quoteSymbol         String
  pairType            String
  priceUsd            Float    @default(0)
  priceChange24h      Float    @default(0)
  volumeUsd24h        Float    @default(0)
  openInterestUsd     Float    @default(0)
  fundingRate         Float    @default(0)
  bidAskSpreadBps     Float    @default(0)
  isActive            Boolean  @default(true)
  updatedAt           DateTime @updatedAt

  @@unique([exchange, symbol])
  @@index([exchange])
  @@index([volumeUsd24h(sort: Desc)])
  @@index([openInterestUsd(sort: Desc)])
}

model CexFundingRate {
  id               String   @id @default(cuid())
  exchange         String
  symbol           String
  fundingRate      Float
  fundingTime      DateTime
  nextFundingTime  DateTime?
  magnitude        String
  timestamp        DateTime @default(now())

  @@index([exchange, symbol, timestamp(sort: Desc)])
  @@index([fundingTime(sort: Desc)])
}

model CexLiquidation {
  id                String   @id @default(cuid())
  exchange          String
  symbol            String
  side              String
  quantity          Float
  liquidationPrice  Float
  estimatedValueUsd Float
  isWhale           Boolean  @default(false)
  whaleTier         String?
  timestamp         DateTime

  @@index([exchange, timestamp(sort: Desc)])
  @@index([estimatedValueUsd(sort: Desc)])
  @@index([isWhale])
}

model BotSignal {
  id         String   @id @default(cuid())
  symbol     String
  direction  String
  confidence Float
  source     String
  grade      String
  entryPrice Float?
  metadata   Json?
  timestamp  DateTime @default(now())

  @@index([symbol, timestamp(sort: Desc)])
  @@index([confidence(sort: Desc)])
}

model BotTrade {
  id        String   @id @default(cuid())
  tradeId   String   @unique
  symbol    String
  action    String
  entryPrice Float
  exitPrice Float?
  stake     Float
  outcome   String
  profitUsd Float   @default(0)
  pips      Float   @default(0)
  strategy  String?
  source    String?
  openTime  DateTime
  closeTime DateTime?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([symbol])
  @@index([outcome])
  @@index([openTime(sort: Desc)])
}

// ─── NEXUS Module System Models ─────────────────────────────

model NewsArticle {
  id          String   @id @default(cuid())
  sourceId    String
  title       String
  summary     String?
  url         String   @unique
  publishedAt DateTime
  assets      String[]
  sentiment   String?
  category    String
  createdAt   DateTime @default(now())

  @@index([publishedAt])
  @@index([assets])
}

model MacroDataPoint {
  id       String   @id @default(cuid())
  seriesId String
  sourceId String
  value    Float
  date     DateTime
  metadata Json?

  @@unique([seriesId, date])
  @@index([seriesId])
}

model MarketSnapshot {
  id        String   @id @default(cuid())
  symbol    String
  sourceId  String
  price     Float
  change24h Float?
  volume24h Float?
  marketCap Float?
  timestamp DateTime @default(now())

  @@index([symbol, timestamp])
}

model ModuleConfig {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, moduleId])
}

model ModuleHealthRecord {
  id          String   @id @default(cuid())
  moduleId    String   @unique
  sourceType  String
  status      String
  lastChecked DateTime @default(now())
  lastSuccess DateTime?
  failureCount Int     @default(0)
  notes       String?
}

model UserApiKey {
  id        String   @id @default(cuid())
  userId    String
  service   String
  apiKey    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, service])
}

model EntityLabel {
  id         String   @id @default(cuid())
  address    String
  chain      String
  label      String
  category   String
  confidence Float    @default(0.5)
  source     String   @default("seeded")
  updatedAt  DateTime @updatedAt

  @@unique([address, chain])
  @@index([chain])
}

model Workspace {
  id         String   @id @default(cuid())
  userId     String   @default("default")
  name       String
  layoutJson Json
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model PrivateLabel {
  id        String   @id @default(cuid())
  userId    String   @default("default")
  address   String
  label     String
  category  String   @default("custom")
  createdAt DateTime @default(now())

  @@unique([userId, address])
  @@index([address])
}

model GapSignal {
  id              String   @id @default(cuid())
  pairLabel       String
  venueA          String
  venueB          String
  priceA          Float
  priceB          Float
  spreadPct       Float
  zScoreVs30dMean Float    @default(0)
  assetClass      String   @default("crypto")
  detectedAt      DateTime @default(now())

  @@index([detectedAt(sort: Desc)])
  @@index([zScoreVs30dMean(sort: Desc)])
}

model WeatherSignal {
  id                   String   @id @default(cuid())
  region               String
  metric               String
  zScoreVsHistorical   Float
  affectedCommodities  String[]
  affectedTickers      String[]
  capturedAt           DateTime @default(now())

  @@index([capturedAt(sort: Desc)])
  @@index([region])
}

model NewsItem {
  id              String   @id @default(cuid())
  source          String
  country         String   @default("global")
  language        String   @default("en")
  headline        String
  summary         String?
  sentimentScore  Float?
  entities        Json?
  publishedAt     DateTime
  url             String
  tier            Int      @default(0)
  localOnlyScore  Float    @default(0)
  createdAt       DateTime @default(now())

  @@index([publishedAt(sort: Desc)])
  @@index([country])
  @@index([source])
}

model MacroSeries {
  id        String   @id @default(cuid())
  seriesId  String
  country   String   @default("US")
  date      DateTime
  value     Float
  unit      String?
  source    String
  createdAt DateTime @default(now())

  @@unique([seriesId, date])
  @@index([seriesId, date(sort: Desc)])
}
